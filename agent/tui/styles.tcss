/* DeepPulse TUI 样式 - 两栏布局 */

Screen {
    background: $surface;
}

#main-container {
    width: 100%;
    height: 1fr;
}

#chat-panel {
    width: 1fr;
    height: 100%;
    background: $background;
}

#right-panel {
    width: 35;
    height: 100%;
    background: $panel;
}

#chat-log {
    height: 1fr;
    border: solid $primary;
    padding: 1;
    scrollbar-gutter: stable;
}

#chat-input {
    dock: bottom;
    height: 3;
    border: solid $accent;
}

#chat-input:focus {
    border: solid $accent;
}

/* 面板样式 */
WatchlistPanel, PortfolioPanel, ToolPanel, DataPanel, MarketPanel {
    margin: 0 1;
}

/* 按钮样式 */
Button {
    min-width: 16;
    height: 3;
    margin: 0 1;
}

Button:hover {
    background: $accent;
}

Button.-primary {
    background: $success;
}

Button.-primary:hover {
    background: $success-lighten-1;
}

/* 消息容器 */
AgentMessageContainer {
    margin: 1 0;
}

/* 确认按钮组 */
ConfirmationButtons {
    height: auto;
    layout: horizontal;
    align: center middle;
    padding: 1;
}
